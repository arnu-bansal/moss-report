generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  password      String
  role          String       @default("student")
  createdAt     DateTime     @default(now())
  submissions   Submission[]
  projects      ProjectMember[]
}

model Project {
  id          String    @id @default(cuid())
  name        String
  language    String    @default("java")
  createdBy   String
  createdAt   DateTime  @default(now())
  submissions Submission[]
  mossRuns    MossRun[]
  members     ProjectMember[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Submission {
  id              String              @id @default(cuid())
  userId          String
  projectId       String
  user            User                @relation(fields: [userId], references: [id])
  project         Project             @relation(fields: [projectId], references: [id])
  createdAt       DateTime            @default(now())
  versions        SubmissionVersion[]
  latestVersionId String?
}

model SubmissionVersion {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  versionNumber Int
  code         String
  filename     String     @default("submission.java")
  isFinal      Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

model MossRun {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id])
  status    String      @default("QUEUED")
  errorText String?
  triggeredBy String?
  createdAt DateTime    @default(now())
  matches   MossMatch[]
}

model MossMatch {
  id                   String             @id @default(cuid())
  mossRunId            String
  mossRun              MossRun            @relation(fields: [mossRunId], references: [id])
  submissionVersionAId String
  submissionVersionBId String
  percentA             Float
  percentB             Float
  mossMatchUrl         String?
  createdAt            DateTime           @default(now())
  segments             MossMatchSegment[]
}

model MossMatchSegment {
  id          String    @id @default(cuid())
  mossMatchId String
  mossMatch   MossMatch @relation(fields: [mossMatchId], references: [id])
  side        String
  startLine   Int
  endLine     Int
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}