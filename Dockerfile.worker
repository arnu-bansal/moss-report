FROM node:20-slim

# Install Perl and OpenSSL
RUN apt-get update && apt-get install -y perl openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files AND prisma schema before npm install
COPY package*.json ./
COPY prisma ./prisma/

# Now npm install + prisma generate will work
RUN npm install

# Copy the moss runner files
COPY src/moss-runner ./src/moss-runner/

WORKDIR /app/src/moss-runner

CMD ["node", "watcher.js"]